{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "@vercel/php",
            "config": {
                "composer": true
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "buildCommand": "",
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    }
}
