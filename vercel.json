{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "php",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.1" // Updated to latest stable PHP runtime
    }
  },
  "routes": [
    {
      "src": "/assets/(css|js|images|favicon)/(.*)",
      "dest": "/public/assets/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php?$1"
    }
  ],
  "buildCommand": "composer install --no-dev --optimize-autoloader"
}

