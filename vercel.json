
{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(css|js|images|favicon)/(.*)",
      "dest": "/public/assets/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php?$1"
    }
  ],
  "outputDirectory": "public"
}
