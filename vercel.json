{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(css|js|images|favicon)/(.*)",
      "dest": "/public/assets/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php?$1"
    }
  ]
}

